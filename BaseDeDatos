______________________________________________________________________________________________________VISTAS

CREATE VIEW proficiencias_de_clase AS 
SELECT c.nombre AS clase, c.tiradas_de_salvacion AS tiradas_de_salvacion, c.talentos AS talentos
FROM clase c

CREATE VIEW clase_arma AS
SELECT c.nombre AS clase, a.nombre AS arma, a.sintesis AS descripcion, a.tipo_de_arma AS tipo
FROM clase c 
JOIN proficiencia_de_arma pda 
ON pda.id_clase = c.id_clase
JOIN armas a
ON a.id_arma = pda.id_arma;

CREATE VIEW clase_armadura AS
SELECT c.nombre AS clase, ar.nombre AS armadura, ar.sintesis AS descripcion, ar.tipo_de_armadura AS tipo
FROM clase c
JOIN proficiencia_de_armadura pdar
ON pdar.id_clase = c.id_clase
JOIN armaduras ar
ON ar.id_armadura = pdar.id_armadura;

_______________________________________________________________________________________________________PROCEDIMIENTO ALMACENADO

DELIMITER //
CREATE PROCEDURE buscador_de_proficiencias (IN arma char(45), IN armadura char(45))
BEGIN
    IF arma!= '' AND armadura != '' THEN
    	SELECT c.nombre
        FROM clase c
        JOIN proficiencia_de_arma pda ON c.id_clase = pda.id_clase
        JOIN armas a ON a.id_arma = pda.id_arma
        JOIN proficiencia_de_armadura pdar ON c.id_clase = pdar.id_clase
        JOIN armaduras ar ON ar.id_armadura = pdar.id_armadura
        WHERE arma = a.nombre AND armadura = ar.nombre;
    ELSE
    		SELECT 'No se hallaron proficiencias';
    	END IF;
 	END//
DELIMITER ;

DELIMITER //
CREATE PROCEDURE buscador_de_hechizos (IN hechizo(70))
BEGIN
    IF hechizo != '' THEN
    	SELECT h.nombre
        FROM hechizos h
        WHERE MATCH (h.nombre) AGAINST (hechizo IN NATURAL LANGUAGE MODE); --Esta sentencia sirve para hacer una busqueda filtrada
    ELSE
    		SELECT 'No se hallaron hechizos';
    	END IF;
 	END//
DELIMITER ;
