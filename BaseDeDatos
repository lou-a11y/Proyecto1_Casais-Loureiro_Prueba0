INSERT INTO hechizos (nombre, sintesis, nivel, escuela, tiempo_de_conjuracion, rango, duracion) VALUES
-- TRUCOS (NIVEL 0) - TODOS
('Salpicadura Acida (Acid Splash)', 'Lanzas una burbuja de ácido a uno o mas objetivos.', 0, 'Conjuración', '1 acción', 60, 'Instantánea'),
('Guardián de la Espada (Blade Ward)', 'Dibujas un simbolo de guarda en el aire y consigues resistencias.', 0, 'Abjuración', '1 acción', 0, '1 ronda'),
('Hoja en Auge (Booming Blade)', 'Encantas tu arma para golpear cuerpo a cuerpo, infligiendo daño adicional si el objetivo se mueve posteriormente.', 0, 'Evocación', '1 acción', 5, '1 ronda'),
('Toque Helado (Chill Touch)', 'Creas una mano esquelética espectral encima de una criatura que lo daña y corta curaciones.', 0, 'Nigromancia', '1 acción', 120, '1 ronda'),
('Controlar Llamas (Control Flames)', 'Controlas llamas no mágicas en un cubo de 5fts. Puedes apagarlas, hacerlas crecer, crear formas o colores.', 0, 'Transmutación', '1 acción', 60, 'Instantánea o 1 hora'),
('Crear Hoguera (Create Bonfire)', 'Creas una hoguera en el suelo que puede quemar criaturas.', 0, 'Conjuración', '1 acción', 60, 'Concentración, hasta 1 minuto'),
('Luces Danzantes (Dancing Lights)', 'Creas hasta cuatro luces que parecen antorchas u orbes de luz. Puedes moverlas hasta 60fts mientras te concentras.', 0, 'Evocación', '1 acción', 120, 'Concentración, hasta 1 minuto'),
('Saber Druidico (Druidcraft)', 'Pequeños efectos druídicos: predecir el tiempo, hacer florecer una flor, crear un sonido de animal, apagar o prender una fuente de luz.', 0, 'Transmutación', '1 acción', 30, 'Instantánea'),
('Explosión sobrenatural (Eldritch Blast)', 'Permite al lanzador disparar un rayo de fuerza.', 0, 'Evocación', '1 acción', 120, 'Instantánea'),
('Descarga de Fuego (Fire Bolt)', 'Lanzas una descarga de fuego a un objetivo.', 0, 'Evocación', '1 acción', 120, 'Instantánea'),
('Amigos (Friends)', 'Obtienes ventaja en en lo que respecta Carisma contra una criatura que no sea hostil. Al finalizar, la criatura sabe que la afectaste con magia y puede volverse hostil.', 0, 'Encantamiento', '1 acción', 0, 'Concentración, hasta 1 minuto'),
('Congelación (Frostbite)', 'Causas un frio entumecedor a una criatura.', 0, 'Evocación', '1 acción', 60, 'Instantánea'),
('Hoja en Llama Verde (Green-Flame Blade)', 'Encantas tu arma con un fuego verde. Al golpear una criatura ese fuego se pasara a una criatura que se encuentre adyacente al objetivo, causandole daño.', 0, 'Evocación', '1 acción', 5, 'Instantánea'),
('Guía (Guidance)', 'Permite a los lanzadores otorgar una bonificación temporal a una criatura.', 0, 'Adivinación', '1 acción', 0, 'Concentración, hasta 1 minuto'),
('Soplido (Gust)', 'Manipulas el aire: puedes mover un objeto pequeño, cambiar la dirección del viento o empujar a una criatura 5 fts.', 0, 'Transmutación', '1 acción', 30, 'Instantánea'),
('Mano Resplandeciente (Hand of Radiance)', 'De tu mano emerge resplandor calcinante, dañando a las criaturas cercanas.', 0, 'Evocación', '1 acción', 5, 'Instantánea'),
('Infestación (Infestation)', 'Llamas a una nube de ácaros/parásitos sobre una criatura.', 0, 'Conjuración', '1 acción', 30, 'Instantánea'),
('Luz (Light)', 'Tocas un objeto para iluminarlo. Puedes elegir un color.', 0, 'Evocación', '1 acción', 0, '1 hora'),
('Rayo Atractor (Lightning Lure)', 'Creas un látigo de energía de rayo que golpea una criatura la cual es atraido y sufre daño.', 0, 'Evocación', '1 acción', 15, 'Instantánea'),
('Mano Magica (Mage Hand)', 'Aparece una mano espectral. Puedes manipular objetos a distancia, abrir puertas, recoger objetos sueltos.', 0, 'Conjuración', '1 acción', 30, '1 minuto'),
('Piedra Magica (Magic Stone)', 'Imbuís de 1 a 3 piedras con magia, haciéndolas proyectiles mágicos.', 0, 'Transmutación', '1 acción adicional', 0, '1 minuto'),
('Remendar (Mending)', 'Reparas una rotura, grieta o desgarro pequeño en un objeto.', 0, 'Transmutación', '1 minuto', 0, 'Instantánea'),
('Mensaje (Message)', 'Susurras un mensaje a una criatura que puedas ver. Solo ella lo oye y puede responder susurrando.', 0, 'Transmutación', '1 acción', 120, '1 ronda'),
('Punzada Mental (Mind Sliver)', 'Transmites a una criatura una punzada de energía psíquica desorientarte, dañándola y aportando una pequeña desventaja', 0, 'Encantamiento', '1 acción', 60, '1 ronda'),
('Ilusión menor (Minor Illusion)', 'Conjura una ilusión, que no se puede mover, para distraer y/o atraer criaturas. ', 0, 'Ilusión', '1 acción', 30, '1 minuto'),
('Moldear Tierra (Mold Earth)', 'Manipulas tierra: excavas, creas tierra difícil, dibujas formas.', 0, 'Transmutación', '1 acción', 30, 'Instantánea o 1 hora'),
('Activar/Desactivar (On/Off)', 'Puedes activar o desactivar cualquier dispositivo de electricidad simple.', 0, 'Transmutación', '1 acción', 60, 'Instantánea'),
('Spray Venenoso (Poison Spray)', 'Extiendes la mano y rocías una nube de gas nocivo a una criatura ', 0, 'Conjuración', '1 acción', 10, 'Instantánea'),
('Prestidigitación (Prestidigitation)', 'Pequeños trucos menores: enfriar, calentar, limpiar, ensuciar, crear pequeños objetos inútiles, crear símbolos.', 0, 'Transmutación', '1 acción', 10, 'Hasta 1 hora'),
('Salvajismo Primigenio (Primal Savagery)', 'Tus uñas/dientes se vuelven filosas. Al atacar cuerpo a cuerpo a una criatura le produces daño acido.', 0, 'Transmutación', '1 acción', 0, 'Instantánea'),
('Producir Llama (Produce Flame)', 'Aparece una llama en tu mano iluminar como una antorcha. Puedes atacar con la misma, haciendo daño de fuego, pero termina el conjuro.', 0, 'Conjuración', '1 acción', 0, '10 minutos'),
('Rayo Gelido (Ray of Frost)', 'Un laser de luz celeste ataca a una criatura, causando daño y reduciendo su movimiento.', 0, 'Evocación', '1 acción', 60, 'Instantánea'),
('Resistencia (Resistance)', 'Tocas a una criatura voluntaria. Antes que termine el hechizo, esta criatura tiene una pequeña ventaja en tiradas de Salvación.', 0, 'Abjuración', '1 acción', 0, 'Concentración, hasta 1 minuto'),
('Flama Sagrada (Sacred Flame)', 'Una resplandor con forma de flama desciende sobre una criatura causándole daño radiante.', 0, 'Evocación', '1 acción', 60, 'Instantánea'),
('Punzada Absorbente (Sapping Sting)', 'Absorbes levemente la vitalidad de una criatura, causándole daño necrótico y cae boca abajo', 0, 'Nigromancia', '1 acción', 30, 'Instantánea'),
('Manipular Agua (Shape Water)', 'Manipulas el agua: mueves, cambias color, crear formas o congelarlo.', 0, 'Transmutación', '1 acción', 30, 'Instantánea o 1 hora'),
('Shillelagh (Shillelagh)', 'Imbuís en un bastón o garrote con la fuerza de la naturaleza. El arma utiliza tu habilidad de casteo para los ataques y daños.', 0, 'Transmutación', '1 acción adicional', 0, '1 minuto'),
('Agarre Shockeante (Shocking Grasp)', 'Rayos danzan entre tus manos transfiriendo cargas de energia a las criaturas que toques. Al atacar una criatura, tiene ventaja si usa armadura de metal. Al ser golpeada: sufre daño electrico y no puede reaccionar.', 0, 'Evocación', '1 acción', 0, 'Instantánea'),
('Estabilizar al Moribundo (Spare the Dying)', 'Tocas a una criatura inconsciente y se estabiliza automáticamente.', 0, 'Nigromancia', '1 acción', 0, 'Instantánea'),
('Espiral de Espadas (Sword Burst)', 'Creas un anillo de espadas espectrales que giran alrededor tuyo. Todas las criaturas que entren en rango sufren daño de fuerza.', 0, 'Conjuración', '1 acción', 5, 'Instantánea'),
('Taumaturgia (Thaumaturgy)', 'Manifiestas un milagro menor: voz potente, temblores inofensivos, sonidos instantaneos desde un punto a eleccion, puertas o ventanas desbloqueadas se abran o se cierren, ojos cambian de apariencia.', 0, 'Transmutación', '1 acción', 30, 'Hasta 1 minuto'),
('Latigo Espinozo (Thorn Whip)', 'Creas un látigo de espinas. Al hacer un ataque magico, causa daño perforante y atrae a las criaturas.', 0, 'Transmutación', '1 acción', 30, 'Instantánea'),
('Aplauso Estruendoso (Thunderclap)', 'Creas un sonido de explosión estruendoso. Las criaturas que estén al alcance sufren daño tormentoso.', 0, 'Evocación', '1 acción', 5, 'Instantánea'),
('Campana de los Muertos (Toll the Dead)', 'Señalas a una criatura y la misma empieza a escuchar un sonido campaneante doloroso, sufriendo daño necrotico. Si al objetivo le falta PVs, sufre mas daño.', 0, 'Nigromancia', '1 acción', 60, 'Instantánea'),
('Golpe Certero (True Strike)', 'Extiendes la mano y señalas a un objetivo. Tu magia te sede percepción sobre la defensa de tu objetivo. En tu siguiente turno, tienes ventaja en tu primer ataque sobre el objetivo.', 0, 'Adivinación', '1 acción', 30, 'Concentración, hasta 1 ronda'),
('Burla Viciosa (Vicious Mockery)', 'Desencadenas una serie de insultos encantados a una criatura. La criatura recibe daño psíquico y desventaja en su siguiente ataque.', 0, 'Encantamiento', '1 acción', 60, 'Instantánea'),
('Virtud (Virtue)', 'Tocas a una criatura, imbuyéndola en vitalidad, garantizándole PVs temporales.', 0, 'Abjuración', '1 acción', 0, '1 ronda'),
('Palabra Radiante (Word of Radiance)', 'Pronuncias una palabra divina y un ardiente resplandor erupciona de ti. Cada criatura que eliges, en el rango, sufre daño radiante.', 0, 'Evocación', '1 acción', 5, 'Instantánea'),

-- NIVEL 1 (TODOS)
('Absorber Elementos (Absorb Elements)', 'El hechizo absorbe parte de energia de un ataque entrante, reduciendo su efecto y almacenandola para tu sigueinte ataque cuerpo a cuerpo. Dependiendo de la fuente ganas resistencia a la misma y tu siguiente ataque tiene daño extra del tipo de la fuente', 1, 'Abjuración', '1 reacción', 0, '1 ronda'),
('Corriente Corrosivo (Acid Stream)', 'Lanzas una corriente de acido en una linea, en una dirección a elección, impregnando a todas las criaturas en la misma. Las criaturas cubiertas en acido reciben daño corrosivo.', 1, 'Evocación', '1 acción', 30, 'Concentracion, hasta 1 minuto'),
('Alarma (Alarm)', 'Creas una alarma. Entre una puerta, una venta o un area de 20fts. Si alguien entra, recibes una señal mental o auditiva.', 1, 'Abjuración', '1 minuto', 30, '8 horas'),
('Amistad Animal (Animal Friendship)', 'Convences a una bestia, de baja inteligencia, de que no eres un peligro.', 1, 'Encantamiento', '1 acción', 30, '24 horas'),
('Arma Arcana (Arcane Weapon)', 'Canalizas energia arcana a un arma simple o marcial que sostienes. Eliges un tipo de daño (acido, hielo, fuego, rayo, estruendo o veneno), que brindara daño extra a tu arma.', 1, 'Transmutación', '1 acción adicional', 0, 'Concentracion, hasta 1 hora'),
('Armadura de Agathys (Armor of Agathys)', 'Una fuerza mágica protectora te envuelve, manifestando a un espectro de hielo que te cubre a ti y a tu equipamiento. Ganas PV temporales y si una criatura te golpea cuerpo a cuerpo recibe daño de hielo.', 1, 'Abjuración', '1 acción', 0, '1 hora'),
('Brazos de Hadar (Arms of Hadar)', 'Invocas el poder de Hadar, filamentos tentaculares oscuros nacen del invocador realizando daño a las criaturas cercanas.', 1, 'Conjuración', '1 acción', 10, 'Instantánea'),
('Perdición (Bane)', 'Encantas hasta 3 criaturas para que tengan una pequeña desventaja en ataques.', 1, 'Encantamiento', '1 acción', 30, 'Concentración, hasta 1 minuto'),
('Vinculo Bestial (Beast Bond)', 'Estableces un vínculo con una bestia (amistosa o encantadas), de poca inteligencia, que tocas. Tiene ventaja en ataques contra criaturas cercanas a ti. Puedes comunicarte con la misma telepáticamente.', 1, 'Adivinación', '1 acción', 0, 'Concentración, hasta 10 minutos'),
('Bendición (Bless)', 'Bendices hasta 3 criaturas. Las criaturas benditas reciben una pequeña ventaja en ataques y tiradas de salvacion. ', 1, 'Encantamiento', '1 acción', 30, 'Concentración, hasta 1 minuto'),
('Manos Ardientes (Burning Hands)', 'Lanzas fuego de tus dedos en un radio conico. Cada criatura sufrira daño de fuego.', 1, 'Evocación', '1 acción', 15, 'Instantánea'),
('Catapulta (Catapult)', 'Catapultas un objeto liviando hasta 90fts en una dirección a elección. Si el objeto golpea a una criatura, ésta deja de moverse y recibe daño contundente.', 1, 'Transmutación', '1 acción', 60, 'Instantánea'),
('Causar Terror (Cause Fear)', 'Asustas a una criatura, que no sea un centinela o un no-muerto. La criatura queda aterrada.', 1, 'Nigromancia', '1 acción', 60, 'Concentración, hasta 1 minuto'),
('Descarga Caótica (Chaos Bolt)', 'Acumulas una masa caotica de energia y se lo lanzas a una criatura. De forma azarosa, la criatura recibira un tipo distinto de daño. La energia caotica puede rebotar en distintas criaturas.', 1, 'Evocación', '1 acción', 120, 'Instantánea'),
('Encantar Persona (Charm Person)', 'Encantas a una criatura para que te considere amigo.', 1, 'Encantamiento', '1 acción', 30, '1 hora'),
('Orbe Cromático (Chromatic Orb)', 'Creas una esfera de energía que puede le puedes aplicar las siguientes propiedades: Acido, Hielo, Fuego, Rayo, Trueno o Veneno.', 1, 'Evocación', '1 acción', 90, 'Instantánea'),
('Colores Cegadores (Color Spray)', 'De tus manos salen ondas deslumbrantes de colores brillantes dejando ciega a todas las criaturas afectadas y las mismas recibiendo gran daño.', 1, 'Ilusión', '1 acción', 15, '1 ronda'),
('Comando (Command)', 'Le ordenas un comando a una criatura que entienda tu lenguaje, que no sea un no-muerto o que no sea hostil hacia ella. El comando es una tarea simple, entre ellos: Acercarce, Soltar, Escapa, Arrastrarse o Detenerse.', 1, 'Encantamiento', '1 acción', 60, '1 ronda'),
('Duelo Forzado (Compelled Duel)', 'Retas a una criatura a un duelo. La criatura queda enfocada hacia ti y por el resto del hechizo tiene desventaja en ataques hacia otras criaturas que no sean hacia ti. Además no puede alejarse de ti.', 1, 'Encantamiento', '1 acción adicional', 30, 'Concentración, hasta 1 minuto'),
('Comprender Lenguajes (Comprehend Languages)', 'Por la duración del hechizo puedes entender cualquier lenguaje hablado o escrito, que este a tu alcance.', 1, 'Adivinación', '1 acción', 0, '1 hora'),
('Crear o Destruir Agua (Create or Destroy Water)', 'Tienes la opción de Emanar o Evaporar agua de un contenedor alternativamente puedes crear lluvia o disipar niebla en un área especifica.', 1, 'Transmutación', '1 acción', 30, 'Instantánea'),
('Curar Heridas (Cure Wounds)', 'Mientras una criatura no sea un centinela o un no-muerto, puedes curar una criatura tocándola.', 1, 'Evocación', '1 acción', 0, 'Instantánea'),
('Detectar el Bien y el Mal (Detect Evil and Good)', 'Detectas aberraciones, celestiales, elementales, hadas, demonios y no-muertos en un rango especifico, asi como su locación. Además en ese mismo rango detectas lugares u objetos consagrados o profanados.', 1, 'Adivinación', '1 acción', 0, 'Concentración, hasta 10 minutos'),
('Detectar Magia (Detect Magic)', 'Sientes la presencia de magia en un rango en especifico. Puedes presenciar una leve aura en cualquier criatura u objeto visible que contenga magia.', 1, 'Adivinación', '1 acción', 0, 'Concentración, hasta 10 minutos'),
('Detectar Venenos y Enfermedades (Detect Poison and Disease)', 'Puedes sentir la presencia y ubicación de criaturas venenosas, venenos, enfermedades y sus tipos.', 1, 'Adivinación', '1 acción', 0, 'Concentración, hasta 10 minutos '),
('Disfrazarse (Disguise Self)', 'Cambias tu apariencia (altura, peso, ropa). No cambia tu tipo de criatura.', 1, 'Ilusión', '1 acción', 0, '1 hora'),
('Susurros Disonantes (Dissonant Whispers)', 'Susurras una disonante melodía a una criatura para causarle un terrible dolor que le provoca una moderada cantidad de daño psíquico y debe usar su reacción inmediatamente para huir de ti.', 1, 'Encantamiento', '1 acción', 60, 'Instantánea'),
('Distorsionar Valor (Distort Value)', 'Redoblas el precio percibido de un objeto agregándole ornamentos y detalles, o reduces a la mitad el precio de un objeto agregándole desgastes y ralladuras.', 1, 'Ilusión', '1 minuto', 0, '8 Horas'),
('Favor Divino (Divine Favor)', 'Tus oraciones te empoderan con un resplandor divino. Tus ataques causan un pequeño daño extra Radiante', 1, 'Evocación', '1 acción adicional', 0, 'Concentración, hasta 1 minuto'),
('Temblor (Earth Tremor)', 'Causas un temblor en la tierra en un radio especifico. Las criaturas en ese radio sufren daño contundente y caen al suelo.', 1, 'Evocación', '1 acción', 10, 'Instantánea'),
('Golpe Enredante (Ensnaring Strike)', 'Tu siguiente ataque con arma desprende una serie de lianas que atrapan a la criatura objetivo. Al inicio de su turno, de estar atrapada, sufre daño perforante.', 1, 'Conjuración', '1 acción adicional', 0, 'Concentración, hasta 1 minuto'),
('Enredar (Entangle)', 'Tomando raíces del suelo, vuelve el terreno difícil en un área especifica. Si una criatura pisa este terreno, quedara restringida por las plantas.', 1, 'Conjuración', '1 acción', 90, 'Concentración, hasta 1 minuto'),
('Retirada Eficiente (Expeditious Retreat)', 'Este hechizo te permite correr mucho mas.', 1, 'Transmutación', '1 acción adicional', 0, 'Concentración, hasta 10 minutos'),
('Fuego Feérico (Faerie Fire)', 'Cada objeto o criatura quedan delineados y los mismos emanan una tenue luz (azul, verde o violeta). Los ataques contra las criaturas u objetos afectados tienen ventaja.', 1, 'Evocación', '1 acción', 60, 'Concentración, hasta 1 minuto'),
('Vida Falsa (False Life)', 'Te refuerzas a ti mismo con una capa necrotica de falsa vida ganando PVs temporales.', 1, 'Nigromancia', '1 acción', 0, '1 hora'),
('Caida de Pluma (Feather Fall)', 'Eliges hasta un maximo de 5 criaturas que caen. Las criaturas afectadas reducen su velocidad de caida, evitando daño por caida.', 1, 'Transmutación', '1 reacción', 60, '1 minuto'),
('Encontrar Familiar (Find Familiar)', 'Obtienes un familiar (animal pequeño). Comparten sentidos, hablas telepaticamente con ella y puedes conjurar hechizos a traves del mismo con un toque.', 1, 'Conjuración', '1 hora', 10, 'Instantánea'),
('Nube de Niebla (Fog Cloud)', 'Creas una densa esfera de niebla en un area, creando profunda oscuridad.', 1, 'Conjuración', '1 acción', 120, 'Concentración, hasta 1 hora'),
('Dedos Gelidos (Frost Fingers)', 'De tus dedos emanan rafagas heladas en un area conica alrededor de ti. Toda criatura atrapada en el area recibe daño gélido y los liquidos no mágicos quedan congelados.', 1, 'Evocación', '1 acción', 15, 'Instantánea'),
('Don de Destreza (Gift of Alacrity)', 'Tocas una criatura bendiciendo a la misma con una moderada ventaja en tiradas de iniciativa.', 1, 'Adivinación', '1 minuto', 0, '8 horas'),
('La Buena Baya (Goodberry)', 'Hasta 10 bayas aparecen en tu mano que sacia el hambre, por un dia, a las criaturas que las consuman.', 1, 'Transmutación', '1 acción', 0, 'Instantánea'),
